{
  "name": "nodaro-backend",
  "version": "1.23.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "tsx watch src/worker.ts",
    "render-worker": "tsx watch src/render-worker.ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "flush-queue": "tsx src/scripts/flush-queue.ts",
    "backfill-video-thumbnails": "tsx src/scripts/backfill-video-thumbnails.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@aws-sdk/client-s3": "^3.980.0",
    "@aws-sdk/lib-storage": "^3.991.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.4.0",
    "@paddle/paddle-node-sdk": "^3.6.0",
    "@remotion/bundler": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@supabase/supabase-js": "^2.49.1",
    "bullmq": "^5.34.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "node-cron": "^4.2.1",
    "replicate": "^1.4.0",
    "sharp": "^0.34.5",
    "youtube-dl-exec": "^3.0.30",
    "zod": "^3.24.2"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/sharp": "^0.31.1",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
