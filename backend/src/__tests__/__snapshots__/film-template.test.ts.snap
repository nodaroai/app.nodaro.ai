white text. Width/height define the canvas footprint in pixels.","alignment":"left","bold":false,"color":"#2d2d44","fontSize":"base","height":260,"italic":false,"label":"Director Notes","text":"Continuity:\\n• Shot 1 → Shot 2: match cliff geometry and sun angle.\\n• Shot 2 → Shot 3: identical key-light direction.\\n\\nAudio:\\n• Score: ambient strings, low register.\\n• SFX: wind bed across all three shots.","textColor":"#ffffff","width":360},"height":260,"id":"tpl_sticky_note","position":{"x":0,"y":320},"type":"sticky-note","width":360},{"data":{"_description":"Utility that joins multiple upstream text outputs into one string. Useful when a prompt is composed from several Text Prompt nodes (e.g., character description + setting + camera). Auto-executes — no Run button needed.","combinedText":"","customSeparator":"","label":"Combine Prompt Parts","separator":"newline"},"height":160,"id":"tpl_combine_text","position":{"x":440,"y":380},"type":"combine-text","width":320},{"data":{"_description":"Utility that splits a multi-line string into individual rows that downstream list/loop nodes can iterate over. Default separator is newline. Auto-executes.","customSeparator":"","label":"Split Script Into Shots","removeEmpty":true,"separator":"double-newline","trimWhitespace":true},"height":160,"id":"tpl_split_text","position":{"x":800,"y":380},"type":"split-text","width":320},{"data":{"_description":"Read-only collector that displays whatever upstream nodes feed it (text, images, video, audio). Use one Preview at the end of each stage so the user can sanity-check the artifacts before moving on. \`previewItems\` and \`itemOrder\` are populated by the runtime — start them empty.","itemOrder":[],"label":"Review Pane","previewItems":[]},"height":320,"id":"tpl_preview","position":{"x":1160,"y":380},"type":"preview","width":480},{"data":{"_description":"Per-shot 'Scene' container — holds the full creative brief for one shot (duration, framing, lens, lighting, mood, dialogue). The skill spawns one Scene node per row of the Shot List. The generated_* fields are runtime-only; start them empty/idle so the canvas shows the node in its un-run state.","activeResultIndex":0,"activeVideoResultIndex":0,"aspectRatio":"16:9","audioAssignments":[],"autoSyncWithScript":false,"cameraAngle":"eye-level","cameraMovement":"static","characters":[],"colorPalette":["amber","teal"],"depthOfField":"deep","dialogue":[],"directorNotes":"Anchor frame; match geometry into shot 2.","duration":5,"executionStatus":"idle","fieldMappings":{},"generatedImageUrl":"","generatedPrompt":"","generatedResults":[],"generatedVideoResults":[],"generatedVideoUrl":"","label":"Scene 1","lensType":"wide","lighting":"natural","locations":[],"mood":["contemplative"],"musicMood":"ambient-strings","narration":"","objects":[],"referenceUrls":[],"sceneName":"Cliff — Wide Establishing","sceneNumber":1,"shotType":"wide","soundEffects":["wind"],"sourceSceneIndex":-1,"sourceScriptNodeId":"","summary":"Lone figure on seaside cliff at golden hour. Wide static.","timeOfDay":"sunset","transitionIn":"cut","transitionOut":"cut","videoExecutionStatus":"idle","videoProvider":"minimax","visualStyle":"cinematic","weather":"clear"},"height":600,"id":"tpl_scene_example","position":{"x":0,"y":720},"type":"scene","width":480}]"`;
