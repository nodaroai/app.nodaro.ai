{
  "name": "@nodaro/cli",
  "version": "1.4.0",
  "description": "Command-line interface for Nodaro — list and run workflows, inspect jobs and executions, manage projects from the terminal.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nodaroai/app.nodaro.ai.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/nodaroai/app.nodaro.ai/tree/main/packages/cli#readme",
  "bugs": "https://github.com/nodaroai/app.nodaro.ai/issues",
  "bin": {
    "nodaro": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile=dist/binaries/nodaro-darwin-arm64",
    "compile:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64   --outfile=dist/binaries/nodaro-darwin-x64",
    "compile:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64  --outfile=dist/binaries/nodaro-linux-arm64",
    "compile:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64    --outfile=dist/binaries/nodaro-linux-x64",
    "compile:windows-x64": "bun build src/index.ts --compile --target=bun-windows-x64  --outfile=dist/binaries/nodaro-windows-x64.exe",
    "compile:all": "npm run compile:darwin-arm64 && npm run compile:darwin-x64 && npm run compile:linux-arm64 && npm run compile:linux-x64 && npm run compile:windows-x64"
  },
  "dependencies": {
    "@inquirer/checkbox": "^5.1.4",
    "@inquirer/confirm": "^6.0.12",
    "@inquirer/input": "^5.0.12",
    "@inquirer/select": "^5.1.4",
    "@nodaro/sdk": "^1.6.0",
    "@nodaro/shared": "^1.9.0",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "@nodaro/prompts": "^1.0.1"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "nodaro",
    "ai",
    "workflow",
    "cli",
    "command-line"
  ]
}
