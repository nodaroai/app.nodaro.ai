{
  "name": "@nodaro/sdk",
  "version": "1.8.0",
  "description": "Typed REST client for the Nodaro API — workflows, jobs, executions, apps, characters, and more.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nodaroai/app.nodaro.ai.git",
    "directory": "packages/client"
  },
  "homepage": "https://github.com/nodaroai/app.nodaro.ai/tree/main/packages/client#readme",
  "bugs": "https://github.com/nodaroai/app.nodaro.ai/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./supabase": {
      "types": "./dist/supabase-browser.d.ts",
      "import": "./dist/supabase-browser.js",
      "require": "./dist/supabase-browser.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nodaro/shared": "^1.14.0",
    "@nodaro/prompts": "^1.4.0"
  },
  "peerDependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.5"
  },
  "peerDependenciesMeta": {
    "@supabase/ssr": {
      "optional": true
    },
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "nodaro",
    "ai",
    "workflow",
    "sdk",
    "client",
    "oauth"
  ]
}
