{
  "name": "@nodaro/shared",
  "version": "1.5.0",
  "description": "Shared types, model catalog, wire contracts, and structural vocabularies for the Nodaro platform and SDK.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nodaroai/app.nodaro.ai.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/nodaroai/app.nodaro.ai/tree/main/packages/shared#readme",
  "bugs": "https://github.com/nodaroai/app.nodaro.ai/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fast-json-patch": "^3.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "engines": {
    "node": ">=22"
  }
}
