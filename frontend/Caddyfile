{
	auto_https off
	admin off
}

:3000 {
	# Security headers (no X-Frame-Options — app supports iframe embedding)
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(self), geolocation=()"
	}

	handle /v1/* {
		# Strip any attempt by an external client to spoof internal-orchestrator
		# auth headers. Backend authenticates internal calls via a shared secret,
		# but stripping here is defense-in-depth — if the secret ever leaks,
		# externally-forwarded headers still can't reach the backend.
		request_header -X-Internal-Orchestrator
		request_header -X-Internal-Orchestrator-Secret
		reverse_proxy 127.0.0.1:9000 {
			# Disable response buffering for SSE streams
			flush_interval -1
		}
	}

	# OAuth discovery endpoints (RFC 8414 + RFC 9728) MUST be served by the
	# backend, not the SPA fallback. Without this, MCP clients (Claude.ai etc.)
	# probing app.nodaro.ai/.well-known/oauth-authorization-server get HTML
	# back and can't parse it — the OAuth handshake fails before it starts.
	handle /.well-known/oauth-authorization-server {
		request_header -X-Internal-Orchestrator
		request_header -X-Internal-Orchestrator-Secret
		reverse_proxy 127.0.0.1:9000
	}
	handle /.well-known/oauth-protected-resource {
		request_header -X-Internal-Orchestrator
		request_header -X-Internal-Orchestrator-Secret
		reverse_proxy 127.0.0.1:9000
	}

	# OG meta tags for social sharing bots (Telegram, WhatsApp, Twitter, Facebook, etc.)
	@social_bot {
		path /app/*
		header_regexp User-Agent (?i)(telegrambot|whatsapp|twitterbot|facebookexternalhit|linkedinbot|slackbot|discordbot|pinterestbot|applebot|googlebot|bingbot)
	}
	handle @social_bot {
		rewrite * /og{uri}
		reverse_proxy 127.0.0.1:9000
	}

	# Bust stale CDN cache for favicon.ico by rewriting to a versioned file
	rewrite /favicon.ico /favicon-v8.ico
	handle {
		encode gzip
		root * /app/frontend/dist
		try_files {path} /index.html
		file_server
	}
	@static path *.js *.css *.png *.svg *.woff2
	header @static Cache-Control "public, max-age=31536000, immutable"
	@favicon path *.ico
	header @favicon Cache-Control "public, max-age=86400"
}
