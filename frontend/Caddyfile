{
	auto_https off
	admin off
}

:{$PORT:8080} {
	handle /v1/* {
		reverse_proxy {$BACKEND_URL:http://localhost:9000}
	}
	handle {
		root * /app/frontend/dist
		try_files {path} /index.html
		file_server
	}
	encode gzip
	@static path *.js *.css *.png *.svg *.ico *.woff2
	header @static Cache-Control "public, max-age=31536000, immutable"
}
