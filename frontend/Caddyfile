:{$PORT:3000} {
    handle /v1/* {
        reverse_proxy {$BACKEND_URL:http://localhost:8000}
    }
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
    encode gzip
    @static path *.js *.css *.png *.svg *.ico *.woff2
    header @static Cache-Control "public, max-age=31536000, immutable"
}
