// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`SelectorConfig — per-mode snapshots > renders the item mode panel 1`] = `
<div
  class="flex flex-col gap-3"
>
  <div
    class="flex flex-col gap-1.5"
  >
    <label>
      Mode
    </label>
    <select
      aria-label="Mode"
    >
      <option
        value="item"
      >
        Item (single index)
      </option>
      <option
        value="range"
      >
        Range (from/to/step)
      </option>
      <option
        value="list"
      >
        List (comma expression)
      </option>
      <option
        value="random"
      >
        Random (seeded)
      </option>
      <option
        value="modulo"
      >
        Modulo (cycle by index)
      </option>
      <option
        value="predicate"
      >
        Predicate (filter)
      </option>
      <option
        value="named-key"
      >
        Named key (look up)
      </option>
    </select>
    <p
      class="text-[10px] text-muted-foreground"
    >
      Pick items by index, range, list, random sample, modulo cycle, predicate, or named key. Per-mode fields appear here once configured.
    </p>
  </div>
  <div
    class="flex flex-col gap-1.5"
  >
    <label
      for="selector-item-index"
    >
      Index
    </label>
    <input
      id="selector-item-index"
      placeholder="3, last, last-1"
      value=""
    />
    <p
      class="text-[10px] text-muted-foreground"
    >
      1-based. Supports 
      <code>
        last
      </code>
       and 
      <code>
        last-N
      </code>
       relative expressions.
    </p>
  </div>
  <p
    class="text-[10px] text-muted-foreground bg-muted/30 rounded-md px-3 py-2 border border-dashed border-border"
  >
    Run the node to see picked / rest counts here.
  </p>
</div>
`;

