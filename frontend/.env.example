# ============================================
# SceneNode.ai - Frontend Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# ============================================

# --------------------------------------------
# Supabase - Database & Auth (Required)
# --------------------------------------------
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --------------------------------------------
# App Config
# --------------------------------------------
VITE_APP_URL=http://localhost:3000

# Edition: 'community' (default), 'business', or 'cloud'
VITE_EDITION=community

# Backend API URL (used by Vite dev proxy and SSE bypass)
VITE_API_URL=http://localhost:8000

# --------------------------------------------
# Paddle Billing (Cloud edition only)
# --------------------------------------------
VITE_PADDLE_CLIENT_TOKEN=test_xxx
VITE_PADDLE_ENVIRONMENT=sandbox

# --------------------------------------------
# Optional - Phase 2+
# --------------------------------------------

# Replicate - AI Models
# REPLICATE_API_TOKEN=r8_xxxxx

# Redis - Job Queue
# REDIS_URL=redis://default:xxxxx@xxxxx:6379

# Cloudflare R2 - Asset Storage
# R2_ACCOUNT_ID=xxxxx
# R2_ACCESS_KEY_ID=xxxxx
# R2_SECRET_ACCESS_KEY=xxxxx
# R2_BUCKET_NAME=scenenode-assets
# R2_PUBLIC_URL=https://assets.yourdomain.com
