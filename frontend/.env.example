# ============================================
# SceneNode.ai - Frontend Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# ============================================

# --------------------------------------------
# Supabase - Database & Auth (Required)
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (server-side only, no NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --------------------------------------------
# App Config
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Edition: 'self-hosted' (default) or 'cloud'
NEXT_PUBLIC_EDITION=self-hosted

# --------------------------------------------
# Paddle Billing
# --------------------------------------------
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_xxx
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox

# --------------------------------------------
# Optional - Phase 2+
# --------------------------------------------

# Replicate - AI Models
# REPLICATE_API_TOKEN=r8_xxxxx

# Redis - Job Queue
# REDIS_URL=redis://default:xxxxx@xxxxx:6379

# Cloudflare R2 - Asset Storage
# R2_ACCOUNT_ID=xxxxx
# R2_ACCESS_KEY_ID=xxxxx
# R2_SECRET_ACCESS_KEY=xxxxx
# R2_BUCKET_NAME=scenenode-assets
# R2_PUBLIC_URL=https://assets.yourdomain.com
