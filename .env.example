# ============================================================================
# Nodaro — Environment Variable Reference
# ============================================================================
# Copy this file to .env and fill in values for your instance.
#
# Required vars are marked [REQUIRED]. Optional vars have sensible defaults.
***REDACTED-OSS-SCRUB***
# ============================================================================

# --- Edition ----------------------------------------------------------------
# community = OSS, no admin / credits / billing
# business  = self-hosted with admin + user mgmt
# cloud     = full SaaS with credits + Stripe
EDITION=community

# --- App URL & CORS --------------------------------------------------------
# Public-facing URL for OAuth redirects, OG tags, embed links.
# In production, set to your instance's HTTPS URL (e.g. https://nodaro.example.com).
PUBLIC_URL=http://localhost:3000

# Comma-separated list of additional allowed CORS origins. localhost:3000 and
# localhost:5173 are always included for dev.
CORS_ORIGIN=

# --- Supabase [REQUIRED] ----------------------------------------------------
# Create a project at https://supabase.com (or self-host).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Anon key (public, used by frontend to talk to Supabase Auth + RLS-gated endpoints)
SUPABASE_ANON_KEY=eyJ...

# --- Redis [REQUIRED for workflow execution] --------------------------------
REDIS_URL=redis://localhost:6379

# --- Cloudflare R2 (S3-compatible storage) ----------------------------------
# Required for asset uploads. Use any S3-compatible store.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nodaro-assets
R2_PUBLIC_URL=
# Optional: extra bucket hostname to allow in the /v1/download + /v1/image-proxy
# allowlist, in addition to the origin derived from R2_PUBLIC_URL. Only needed
# if assets are served from a second host (e.g. a raw pub-<id>.r2.dev bucket
# host alongside a custom CDN domain). Leave empty otherwise.
R2_PUBLIC_FALLBACK_DOMAIN=

# --- AI Providers (at least one recommended) --------------------------------
KIE_API_KEY=
REPLICATE_API_TOKEN=
# Required in Cloud edition for character LoRA training webhook signature
# verification (Standard Webhooks HMAC). Get from
# `replicate.webhooks.default.secret` or the Replicate dashboard.
REPLICATE_WEBHOOK_SECRET=
# Operational kill-switch for the character LoRA inference path. When "false",
# trained-character generations fall back to standard reference-image
# injection. Training routes are unaffected. Default: true.
# CHARACTER_LORA_ROUTING_ENABLED=true
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
APIFY_API_TOKEN=

# KIE.ai account unique ID for the credit-audit API (constant per account).
# Only needed if you want admin credit-audit reports.
KIE_UNIQUE_ID=

# --- Internal secrets [REQUIRED] -------------------------------------------
# Generate: openssl rand -hex 32
INTERNAL_ORCHESTRATOR_SECRET=

# Generate: openssl rand -hex 32
SOCIAL_ENCRYPTION_KEY=

# --- Server tuning (optional) -----------------------------------------------
PORT=8000
HOST=0.0.0.0
NODE_ENV=development

# Concurrency limits
MAX_CONCURRENT_NODES_PER_EXECUTION=6
VIDEO_WORKER_CONCURRENCY=50
ORCHESTRATOR_CONCURRENCY=20
RENDER_WORKER_CONCURRENCY=2
FFMPEG_CONCURRENCY=4

# Number of parallel browser tabs for Remotion renders.
# Leave unset to use Remotion's default (50% of CPU cores).
# REMOTION_CONCURRENCY=

# --- Admin owner gate (business / cloud, optional) --------------------------
# Email of the platform owner whose super_admin role is protected from changes
# by other admins. Empty (default) = no protected owner. Set the SAME value in
# the frontend build arg VITE_PLATFORM_OWNER_EMAIL for the matching UI guard.
PLATFORM_OWNER_EMAIL=

# --- Stripe (cloud edition only) --------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
#
# NOTE: Stripe product/price IDs are currently hardcoded in
# backend/src/ee/billing/stripe-config.ts and frontend/src/lib/pricing-data.ts.
# Self-hosted Cloud operators must replace those with their own Stripe IDs.
# (Tracked for migration to env vars — see the OSS-readiness audit.)

# --- Social OAuth (optional, per platform) ----------------------------------
# Required only if social-publishing nodes are used.
# META_APP_ID=
# META_APP_SECRET=
# META_FACEBOOK_CONFIG_ID=
# META_INSTAGRAM_CONFIG_ID=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# --- Frontend Vite vars (set during Docker build, prefix VITE_) -------------
# VITE_API_URL=http://localhost:8000
# VITE_EDITION=community
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_APP_URL=
# VITE_STRIPE_PUBLISHABLE_KEY=
# VITE_FREECUT_URL=
# VITE_AUDIOMASS_URL=
# Optional analytics (empty = disabled; nothing phones home). Set only if you
# want to send telemetry to YOUR OWN Google Analytics / Microsoft Clarity.
# VITE_GA_ID=
# VITE_CLARITY_ID=
# Owner gate UI (match backend PLATFORM_OWNER_EMAIL). Empty = no protected owner.
# VITE_PLATFORM_OWNER_EMAIL=
